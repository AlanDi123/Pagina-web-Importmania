# ============================================
# BASE DE DATOS (Supabase PostgreSQL)
# ============================================
# DATABASE_URL: URL de conexión a PostgreSQL con PgBouncer (transaccional)
# DIRECT_URL: URL de conexión directa (para migraciones)
# Reemplazar [password], [project] con tus datos de Supabase
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# ============================================
# SUPABASE
# ============================================
# NEXT_PUBLIC_SUPABASE_URL: URL de tu proyecto Supabase (ej: https://xxxxx.supabase.co)
# NEXT_PUBLIC_SUPABASE_ANON_KEY: Clave anónima pública (desde Settings > API en Supabase)
# SUPABASE_SERVICE_ROLE_KEY: Clave de servicio (SECRETA, solo servidor)
NEXT_PUBLIC_SUPABASE_URL="https://[project].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ============================================
# NEXTAUTH
# ============================================
# NEXTAUTH_URL: URL base de tu aplicación (producción o localhost)
# NEXTAUTH_SECRET: Clave secreta para encriptar sesiones
# Generar con: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="tu-secreto-aqui-generado-con-openssl"

# ============================================
# OAUTH - GOOGLE
# ============================================
# GOOGLE_CLIENT_ID: Client ID de Google Cloud Console
# GOOGLE_CLIENT_SECRET: Client Secret de Google Cloud Console
# Configurar en: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="XXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXX"

# ============================================
# MERCADOPAGO (Argentina)
# ============================================
# MP_ACCESS_TOKEN: Access Token de MercadoPago (desde Panel de Desarrollador)
# NEXT_PUBLIC_MP_PUBLIC_KEY: Public Key (se expone al cliente)
# MP_WEBHOOK_SECRET: Secret para validar webhooks (desde Notificaciones)
# Modo Sandbox (testing): usar credenciales de test
# Modo Producción: usar credenciales de production
MP_ACCESS_TOKEN="APP_USR-XXXXXXXXXXXXXXXX-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"
NEXT_PUBLIC_MP_PUBLIC_KEY="APP_USR-XXXXXXXXXXXXXXXX"
MP_WEBHOOK_SECRET="tu-webhook-secret-aqui"

# ============================================
# EMAIL (Resend)
# ============================================
# RESEND_API_KEY: API Key de Resend (https://resend.com)
# EMAIL_FROM: Email remitente (debe estar verificado en Resend)
# Formato: "Nombre <email@dominio.com>"
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
EMAIL_FROM="iMPORTMANIA <hola@importmania.com.ar>"

# ============================================
# ANALYTICS (Configurables también desde admin)
# ============================================
# NEXT_PUBLIC_GA_ID: Google Analytics 4 Measurement ID
# NEXT_PUBLIC_FB_PIXEL_ID: Facebook Pixel ID
# NEXT_PUBLIC_TIKTOK_PIXEL_ID: TikTok Pixel ID
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_FB_PIXEL_ID="1234567890"
NEXT_PUBLIC_TIKTOK_PIXEL_ID="XXXXXXXXXX"

# ============================================
# APP
# ============================================
# NEXT_PUBLIC_APP_URL: URL pública de tu tienda (para sitemap, emails, etc.)
# NEXT_PUBLIC_WHATSAPP_NUMBER: Número de WhatsApp Business (código país + número)
# Ejemplo Argentina: 5411XXXXXXXX
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP_NUMBER="541131270501"

# ============================================
# RATE LIMITING (Upstash Redis - Opcional)
# ============================================
# UPSTASH_REDIS_REST_URL: URL de Redis (https://upstash.com)
# UPSTASH_REDIS_REST_TOKEN: Token de Redis
# Usado para rate limiting en login, registro, webhooks
UPSTASH_REDIS_REST_URL="https://XXX.upstash.io"
UPSTASH_REDIS_REST_TOKEN="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ============================================
# WEB PUSH NOTIFICATIONS (Opcional)
# ============================================
# WEB_PUSH_PUBLIC_KEY: VAPID public key para notificaciones push
# WEB_PUSH_PRIVATE_KEY: VAPID private key (SECRETA)
# Generar con: web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY="tu-vapid-public-key"
WEB_PUSH_PRIVATE_KEY="tu-vapid-private-key"
WEB_PUSH_SUBJECT="mailto:soporte@importmania.com.ar"
